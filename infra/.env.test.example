# Test stack environment — copy to .env.test and fill in RELAY_TOKEN.
# Ports are intentionally different from dev to allow both stacks to run in parallel.
FRONTEND_PORT=5010
RELAY_PORT=5011
BACKEND_PORT=5012
RELAY_TOKEN=change_me_test
REPOS_ROOT=/home/juska/repos
# Absolute path to the test DB file (backend wipes it on startup when NODE_ENV=test).
DB_PATH=/home/juska/repos/alf/data/test/alf-test.db
NODE_ENV=test
# Keep test impl for E2E tests — no LLM cost or flakiness.
DEFAULT_IMPL=test
