[Unit]
Description=Alf Test — Frontend (static build)
After=alf-test-relay.service

[Service]
Type=simple
WorkingDirectory=%h/repos/alf/frontend
ExecStartPre=%h/repos/alf/infra/scripts/run-with-profile.sh %h/repos/alf/frontend/node_modules/.bin/vite build
ExecStart=%h/repos/alf/infra/scripts/run-with-profile.sh %h/repos/alf/frontend/node_modules/.bin/vite preview
EnvironmentFile=%h/repos/alf/infra/.env.test
Restart=on-failure
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=alf-test.target
