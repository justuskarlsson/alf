[Unit]
Description=Alf Dev — Frontend
After=alf-dev-relay.service

[Service]
Type=simple
WorkingDirectory=%h/repos/alf/frontend
ExecStart=%h/repos/alf/infra/scripts/run-with-profile.sh %h/repos/alf/frontend/node_modules/.bin/vite
EnvironmentFile=%h/repos/alf/infra/.env.dev
Restart=on-failure
RestartSec=2
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=alf-dev.target
